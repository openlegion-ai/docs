              "quickstart"
            ]
          },
          {
            "group": "Concepts",
            "pages": [
              "concepts/architecture",
              "concepts/security"
            ]
          },
          {
            "group": "Features",
            "pages": [
              "features/agents",
              "features/workflows",
              "features/memory",
              "features/triggering",
              "features/channels",
              "features/mcp",
              "features/cost-tracking"
            ]
          }
        ]
      },
      {
        "tab": "Reference",
        "groups": [
          {
            "group": "Reference",
            "pages": [
              "reference/cli",
              "reference/configuration",
              "reference/agent-tools"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
